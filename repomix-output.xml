              <p className="text-white/60">Essayez d'ajuster vos filtres.</p>
            </div>
          )}
        </section>
      </div>
      <ProjectModal
        project={activeProject}
        open={!!activeProject}
        onOpenChange={() => setActiveProject(null)}
      />
    </section>
  );
}

